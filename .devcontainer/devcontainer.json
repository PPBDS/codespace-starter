{
  "name": "R Data Science",

  // Base tidyverse image maintained by rocker
  "image": "ghcr.io/rocker-org/devcontainer/tidyverse:4",

  "features": {
    // GitHub CLI is occasionally useful for authentication tasks
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // Prevent tools from trying to open external browser windows
  // (which do not work well inside Codespaces)
  "remoteEnv": {
    "BROWSER": "/usr/bin/true"
  },

  "customizations": {
    "vscode": {

      // Extensions students actually need
      "extensions": [
        "reditorsupport.r",
        "rdebugger.r-debugger",
        "quarto.quarto",
        "PPBDS.vscode-r-tutorials"
      ],

      "settings": {

        // Use arf (Rust-based R console) instead of the default R terminal.
        "r.rterm.linux": "/home/rstudio/.cargo/bin/arf",

        // Required for arf-style consoles to handle pasted code correctly.
        "r.bracketedPaste": true,

        // Render plots inside VS Code via the httpgd graphics device
        // instead of opening an external window (which doesn't work in Codespaces).
        "r.plot.useHttpgd": true,

        // Prevent VS Code from nagging to relaunch the terminal when
        // environment variables change.
        "terminal.integrated.environmentChangesRelaunch": false,

        // Don't show a Welcome tab or release notes on startup.
        "workbench.startupEditor": "none",

        // Auto-stage all changes on commit so students don't get a confusing
        // dialog asking whether to stage files.
        "git.enableSmartCommit": true,

        // Don't prompt "are you sure?" before push/pull.
        "git.confirmSync": false,

        // Don't fetch from the remote in the background. Keeps things
        // predictable and avoids confusing status bar changes.
        "git.autofetch": false,

        // Auto-save files after a short delay. Prevents the #1 beginner
        // problem: "my code isn't working" because the file wasn't saved.
        "files.autoSave": "afterDelay",

        // Stop VS Code from suggesting random extensions students don't need.
        "extensions.ignoreRecommendations": true,

        // Prevent the "open repository in parent folder?" prompt that
        // confuses students who don't understand nested git repos.
        "git.openRepositoryInParentFolders": "never"
      }
    },

    "codespaces": {
      // Opens READY.md immediately (shows "Setting up..." message).
      // postCreateCommand overwrites it with "Ready" when setup completes.
      "openFiles": [
        ".devcontainer/READY.md"
      ]
    }
  },

  // Install arf console, required R packages, and custom keybindings,
  // then overwrite READY.md to signal that the Codespace is ready.
  //
  // Keybindings: The R extension for VS Code doesn't expose a "restart R"
  // command, so we install a keybindings.json that binds Ctrl+Shift+0
  // (mirroring Positron's Cmd+Shift+0) to send q('no') to the terminal,
  // which quits R without saving the workspace. The R extension
  // auto-launches a new session when code is next sent. The keybindings
  // source file lives at .devcontainer/keybindings.json. We pre-create
  // the .vscode-remote/data/User directory here; VS Code discovers the
  // file when it attaches after postCreateCommand finishes.
  //
  // READY.md is updated last so students don't see "Ready" until
  // everything is truly finished.
  "postCreateCommand": "printf '#!/bin/sh\\nexit 0' | sudo tee /usr/local/bin/xdg-open > /dev/null && sudo chmod +x /usr/local/bin/xdg-open && curl --proto '=https' --tlsv1.2 -LsSf https://github.com/eitsupi/arf/releases/latest/download/arf-console-installer.sh | sh && R -e 'install.packages(c(\"tutorial.helpers\", \"quarto\"))' && mkdir -p $HOME/.vscode-remote/data/User && cp .devcontainer/keybindings.json $HOME/.vscode-remote/data/User/keybindings.json && printf '# Codespace Ready\\n\\nYou can begin working now.\\n\\nYou may close the right panel and dismiss any setup prompts.' > .devcontainer/READY.md"
}